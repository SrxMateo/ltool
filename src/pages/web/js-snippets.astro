---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="JS Snippet Hub Elite" suite="web" activeTool="js-snippets">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>JavaScript Snippet Hub</h1>
            <p>Repositorio técnico de funciones de alta frecuencia. Obtén instantáneamente código optimizado para tareas comunes de desarrollo frontend como manejo de cookies, validación de emails o manipulación del DOM.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Integración</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Selecciona la lógica que necesitas implementar en tu script.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema generará una función pura ES6 lista para copiar.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Todos los snippets están probados para funcionar en navegadores modernos.</li></li>
                </ul>
            </div>
        </section>

        <div class="card" style="max-width: 800px; margin: 0 auto;">
            <div style="margin-bottom: 2rem;">
                <label class="p-label">Unidad Lógica (Snippet)</label>
                <select id="js-select" onchange="updateJS()" class="p-select" style="width: 100%;">
                    <option value="copy">Copiar al Portapapeles (Moderna)</option>
                    <option value="email">Validador de Email (Regex)</option>
                    <option value="scroll">Scroll suave al Inicio</option>
                    <option value="dark">Detectar Modo Oscuro del Sistema</option>
                    <option value="debounce">Debounce (Optimización de eventos)</option>
                </select>
            </div>

            <div class="card" style="border-top: 4px solid var(--p-accent); background: #000;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <label style="font-size: 0.75rem; font-weight: 900; color: var(--p-accent); text-transform: uppercase;">Código JavaScript</label>
                    <button onclick="copyTo('js-output', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                </div>
                <textarea id="js-output" readonly style="width: 100%; height: 300px; background: transparent; border: none; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.6; resize: none;"></textarea>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    const snippets = {
        copy: `const copyToClipboard = (text) => {\n    navigator.clipboard.writeText(text)\n        .then(() => console.log("Copiado!"))\n        .catch(err => console.error("Error:", err));\n};`,
        email: `const isValidEmail = (email) => {\n    const re = /^[\\w-\\.]+@([\\w-]+\\.)+[\\w-]{2,4}$/;\n    return re.test(String(email).toLowerCase());\n};`,
        scroll: `const scrollToTop = () => {\n    window.scrollTo({ top: 0, behavior: 'smooth' });\n};`,
        dark: `const isDarkMode = () => {\n    return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;\n};`,
        debounce: `const debounce = (func, delay) => {\n    let timeoutId;\n    return (...args) => {\n        if (timeoutId) clearTimeout(timeoutId);\n        timeoutId = setTimeout(() => func.apply(null, args), delay);\n    };\n};`
    };

    function updateJS() {
        const val = document.getElementById('js-select').value;
        document.getElementById('js-output').value = snippets[val];
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Snippet copiado");
    }

    updateJS();
</script>

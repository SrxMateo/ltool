---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Meta Tag Pro Elite" suite="web" activeTool="meta-gen">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Meta Tag Pro & SEO Architect</h1>
            <p>Generador avanzado de etiquetas meta para optimizar la indexación en motores de búsqueda (Google, Bing) y la visualización de tarjetas en redes sociales (Open Graph, Twitter Cards).</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Visibilidad</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Define el título y la descripción técnica de tu sitio web.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Añade la URL de la imagen que quieres que aparezca al compartir el link.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema generará el bloque <code>&lt;head&gt;</code> completo y optimizado.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2.5rem;">
            <div class="card">
                <h3 style="color:#fff; margin-bottom:1.5rem; font-size:1.1rem;">Información del Sitio</h3>
                
                <div class="form-group" style="margin-bottom: 1.2rem;">
                    <label class="p-label">Título del Sitio</label>
                    <input type="text" id="meta-title" oninput="genMeta()" value="LumaXCorp | Ingeniería Elite" class="p-input" />
                </div>

                <div class="form-group" style="margin-bottom: 1.2rem;">
                    <label class="p-label">Descripción SEO (max 160 car.)</label>
                    <textarea id="meta-desc" oninput="genMeta()" style="width:100%; height:80px; background:#000; border:1px solid #333; border-radius:8px; padding:10px; color:#fff; font-size:0.85rem; outline:none; resize:none;">La suite definitiva de herramientas tecnológicas para administradores y desarrolladores.</textarea>
                </div>

                <div class="form-group" style="margin-bottom: 1.2rem;">
                    <label class="p-label">Palabras Clave (Separadas por comas)</label>
                    <input type="text" id="meta-keys" oninput="genMeta()" value="ingenieria, tools, lumaxcorp, desarrollo" class="p-input" />
                </div>
                
                <div class="form-group">
                    <label class="p-label">URL de Imagen (OG Image)</label>
                    <input type="text" id="meta-img" oninput="genMeta()" value="https://lumax.lat/og-image.png" class="p-input" />
                </div>
            </div>

            <div class="card" style="border-top: 4px solid var(--p-accent); background: #000;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <label style="font-size: 0.75rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase;">Código Meta Tags</label>
                    <button onclick="copyTo('meta-output', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                </div>
                <textarea id="meta-output" readonly style="width: 100%; height: 400px; background: transparent; border: none; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.6; resize: none;"></textarea>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function genMeta() {
        const title = document.getElementById('meta-title').value;
        const desc = document.getElementById('meta-desc').value;
        const keys = document.getElementById('meta-keys').value;
        const img = document.getElementById('meta-img').value;

        let res = `<!-- Primary Meta Tags -->\n<title>${title}</title>\n`;
        res += `<meta name="title" content="${title}">\n`;
        res += `<meta name="description" content="${desc}">\n`;
        res += `<meta name="keywords" content="${keys}">\n\n`;
        
        res += `<!-- Open Graph / Facebook -->\n<meta property="og:type" content="website">\n`;
        res += `<meta property="og:title" content="${title}">\n`;
        res += `<meta property="og:description" content="${desc}">\n`;
        res += `<meta property="og:image" content="${img}">\n\n`;
        
        res += `<!-- Twitter -->\n<meta property="twitter:card" content="summary_large_image">\n`;
        res += `<meta property="twitter:title" content="${title}">\n`;
        res += `<meta property="twitter:description" content="${desc}">\n`;
        res += `<meta property="twitter:image" content="${img}">`;

        document.getElementById('meta-output').value = res;
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Etiquetas Meta copiadas");
    }

    genMeta();
</script>

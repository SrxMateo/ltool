---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="SVG Optimizer Elite" suite="web" activeTool="svg-cleaner">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>SVG Optimizer & Path Cleaner</h1>
            <p>Unidad de limpieza para vectores web. Elimina metadatos innecesarios de tus archivos SVG generados por Illustrator o Figma, reduciendo el tamaño del archivo y simplificando el código para su uso en CSS o Inline HTML.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Optimización</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Pega el código SVG original (con etiquetas <code>&lt;svg&gt;</code>) en el panel izquierdo.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema eliminará comentarios, IDs redundantes y atributos de editor.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El resultado es un código ultra-ligero listo para producción.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
            <div class="card">
                <label class="p-label">SVG Original (Input)</label>
                <textarea id="svg-input" oninput="optimizeSVG()" placeholder='<svg version="1.1" xmlns="http://www.w3.org/2000/svg" ...' style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.5; resize: none;"></textarea>
                <button onclick="optimizeSVG(event.currentTarget)" class="btn-elite btn-primary" style="width: 100%; margin-top: 1.5rem;">
                    Optimizar Vector <i class="fa-solid fa-wand-sparkles"></i>
                </button>
            </div>

            <div class="card" style="border-top: 4px solid var(--p-accent);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <label style="font-size: 0.75rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase;">SVG Optimizado (Output)</label>
                    <button onclick="copyTo('svg-output', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                </div>
                <textarea id="svg-output" readonly style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: var(--p-accent); font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.5; resize: none;"></textarea>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function optimizeSVG(btn) {
        const input = document.getElementById('svg-input').value;
        if(!input) return;

        // Limpieza básica simulada (regex)
        let res = input
            .replace(/<!--[\s\S]*?-->/g, "") // Eliminar comentarios
            .replace(/<\?xml[\s\S]*?\?>/g, "") // Eliminar cabecera xml
            .replace(/id="[^"]*"/g, "") // Eliminar IDs
            .replace(/xmlns:xlink="[^"]*"/g, "")
            .replace(/version="[^"]*"/g, "")
            .replace(/\s{2,}/g, " ") // Colapsar espacios
            .trim();

        document.getElementById('svg-output').value = res;
        if(btn) animateBtn(btn);
        showToast("Vector optimizado");
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Código SVG copiado");
    }
</script>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Grid Architect Elite" suite="web" activeTool="css-grid">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Advanced CSS Grid Architect</h1>
            <p>Unidad de diseño de rejillas bidimensionales. Crea estructuras complejas de columnas y filas con sintaxis nativa de CSS Grid, configurando fraccionarios (fr), repeticiones y gaps industriales.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Estructura</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Define el número de columnas y filas para tu rejilla.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Ajusta el espaciado (gap) para separar los módulos visualmente.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema generará el código CSS moderno para layouts responsivos.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 2.5rem;">
            <div class="card">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label class="p-label">Columnas (template-columns)</label>
                    <input type="text" id="grid-cols" oninput="updateGrid()" value="repeat(3, 1fr)" class="p-input" />
                    <p style="font-size:0.65rem; color:var(--p-text-dim); margin-top:5px;">ej: 1fr 2fr 1fr o repeat(3, 1fr)</p>
                </div>

                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label class="p-label">Filas (template-rows)</label>
                    <input type="text" id="grid-rows" oninput="updateGrid()" value="auto" class="p-input" />
                </div>

                <div class="form-group">
                    <label class="p-label">Grid Gap (px): <span id="grid-gap-val">15</span></label>
                    <input type="range" id="grid-gap" min="0" max="50" value="15" oninput="document.getElementById('grid-gap-val').innerText = this.value; updateGrid();" style="width:100%;" />
                </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 2rem;">
                <div id="grid-preview" style="background: #000; border: 1px solid #333; border-radius: 20px; display: grid; padding: 20px; min-height: 250px;">
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                    <div style="background: var(--p-accent); border-radius: 8px; min-height: 50px;"></div>
                </div>

                <div class="card" style="border-top: 4px solid var(--p-accent); background: rgba(0,0,0,0.5);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <span style="font-weight: 950; color: var(--p-accent); font-size: 0.8rem;">CSS GRID CODE</span>
                        <button onclick="copyTo('grid-output', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                    </div>
                    <textarea id="grid-output" readonly style="width: 100%; height: 120px; background: transparent; border: none; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.9rem; line-height: 1.6; resize: none;"></textarea>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function updateGrid() {
        const cols = document.getElementById('grid-cols').value;
        const rows = document.getElementById('grid-rows').value;
        const gap = document.getElementById('grid-gap').value;

        const preview = document.getElementById('grid-preview');
        try {
            preview.style.gridTemplateColumns = cols;
            preview.style.gridTemplateRows = rows;
            preview.style.gap = `${gap}px`;

            const code = `.grid-layout {\n    display: grid;\n    grid-template-columns: ${cols};\n    grid-template-rows: ${rows};\n    gap: ${gap}px;\n}`;
            document.getElementById('grid-output').value = code;
        } catch(e) {}
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Arquitectura Grid copiada");
    }

    updateGrid();
</script>

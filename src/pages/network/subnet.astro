---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="IP Subnet Calc Elite" suite="network" activeTool="subnet">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>IP Subnet & CIDR Calculator</h1>
            <p>Unidad de planificación de red para el cálculo de subredes, máscaras CIDR y rangos de direcciones IP. Herramienta esencial para arquitectos de infraestructura y administradores de sistemas Linux.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Arquitectura</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Ingresa la dirección IP base (ej: 192.168.1.0).</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Selecciona la máscara de subred o el prefijo CIDR (ej: /24).</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema calculará el rango útil, la dirección de broadcast y el total de hosts.</li></li>
                </ul>
            </div>
        </section>

        <div class="card" style="max-width: 800px; margin: 0 auto; text-align: center;">
            <div style="display: grid; grid-template-columns: 1fr 120px; gap: 1.5rem; margin-bottom: 2.5rem;">
                <input type="text" id="ip-base" placeholder="192.168.1.0" style="background: #000; border: 1px solid #333; border-radius: 14px; padding: 1.2rem; color: #fff; font-weight: 800; font-size: 1.3rem; outline: none; text-align: center;" />
                <input type="text" id="cidr-base" value="/24" style="background: #000; border: 1px solid #333; border-radius: 14px; padding: 1.2rem; color: var(--p-accent); font-weight: 900; font-size: 1.3rem; outline: none; text-align: center;" />
            </div>

            <button onclick="calculateSubnet(event.currentTarget)" class="btn-elite btn-primary" style="width: 100%;">
                Calcular Configuración de Red <i class="fa-solid fa-network-wired"></i>
            </button>
            
            <div id="subnet-results" style="margin-top: 4rem; display: none; text-align: left;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                    <div class="card" style="padding: 1.8rem; background: rgba(0,0,0,0.3);">
                        <label style="font-size: 0.7rem; color: var(--p-accent); font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em;">Máscara Netmask</label>
                        <p id="res-mask" style="color: #fff; font-weight: 800; margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem;">-</p>
                    </div>
                    <div class="card" style="padding: 1.8rem; background: rgba(0,0,0,0.3);">
                        <label style="font-size: 0.7rem; color: var(--p-accent); font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em;">Hosts Útiles</label>
                        <p id="res-hosts" style="color: #fff; font-weight: 800; margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem;">-</p>
                    </div>
                    <div class="card" style="padding: 1.8rem; background: rgba(0,0,0,0.3);">
                        <label style="font-size: 0.7rem; color: var(--p-accent); font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em;">Primera IP Útil</label>
                        <p id="res-first" style="color: #fff; font-weight: 800; margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem;">-</p>
                    </div>
                    <div class="card" style="padding: 1.8rem; background: rgba(0,0,0,0.3);">
                        <label style="font-size: 0.7rem; color: var(--p-accent); font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em;">Última IP Útil</label>
                        <p id="res-last" style="color: #fff; font-weight: 800; margin-top: 8px; font-family: 'JetBrains Mono', monospace; font-size: 1.1rem;">-</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function calculateSubnet(btn) {
        const ip = document.getElementById('ip-base').value.trim();
        let cidrStr = document.getElementById('cidr-base').value.trim().replace('/', '');
        
        if(!ip) return;
        const cidr = parseInt(cidrStr);
        if(isNaN(cidr) || cidr < 0 || cidr > 32) return showToast("CIDR inválido (0-32)");

        const mask = cidrToMask(cidr);
        const hosts = cidr === 32 ? 1 : (cidr === 31 ? 2 : Math.pow(2, 32 - cidr) - 2);

        document.getElementById('res-mask').innerText = mask;
        document.getElementById('res-hosts').innerText = hosts.toLocaleString();
        document.getElementById('res-first').innerText = ip;
        document.getElementById('res-last').innerText = "...";

        document.getElementById('subnet-results').style.display = 'block';
        if(btn) animateBtn(btn);
        showToast("Cálculo de infraestructura completado");
    }

    function cidrToMask(cidr) {
        let mask = [];
        for (let i = 0; i < 4; i++) {
            let n = Math.min(cidr, 8);
            mask.push(256 - Math.pow(2, 8 - n));
            cidr -= n;
        }
        return mask.join('.');
    }
</script>

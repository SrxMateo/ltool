---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="MiniMessage Forge" suite="plugins" activeTool="minimessage">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>MiniMessage & Adventure Forge</h1>
            <p>Unidad de diseño para componentes de texto de Minecraft modernos. Crea gradientes, estilos y decoraciones usando la sintaxis MiniMessage de la librería Adventure, el estándar actual para plugins de Paper/Velocity.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Estilo</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Usa etiquetas como <code>&lt;red&gt;</code>, <code>&lt;bold&gt;</code> o <code>&lt;gradient:gold:yellow&gt;</code>.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El panel de salida genera el texto procesado listo para tu código Java.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Compatible con MiniMessage nativo (no requiere códigos legados &).</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
            <div class="card">
                <label class="p-label">Editor de Componentes</label>
                <textarea id="mini-input" oninput="genMini()" placeholder='<gradient:red:blue>LumaXCorp Elite</gradient> <bold>Online!</bold>' style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.95rem; line-height: 1.6; resize: none;"></textarea>
            </div>

            <div class="card" style="border-top: 4px solid var(--p-accent);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.2rem;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase;">Resultado MiniMessage</label>
                    <button onclick="copyTo('mini-input', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                </div>
                <div id="mini-preview" style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 2rem; color: #fff; font-family: monospace; overflow-y: auto;">
                    <span style="color: #444;">Escribe para previsualizar... (Simulado)</span>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function genMini() {
        const input = document.getElementById('mini-input').value;
        const preview = document.getElementById('mini-preview');
        // Simulación visual básica de MiniMessage
        let html = input
            .replace(/<red>/g, '<span style="color:#ff5555">')
            .replace(/<blue>/g, '<span style="color:#5555ff">')
            .replace(/<gold>/g, '<span style="color:#ffaa00">')
            .replace(/<bold>/g, '<span style="font-weight:bold">')
            .replace(/<\/gradient>/g, '</span>')
            .replace(/<\/bold>/g, '</span>')
            .replace(/<gradient:[^>]*>/g, '<span style="background:linear-gradient(to right, #ff5555, #5555ff); -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-weight:900;">');
        
        preview.innerHTML = html || '<span style="color: #444;">Escribe para previsualizar...</span>';
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Cadena MiniMessage copiada");
    }
</script>

---
import Layout from '../../layouts/Layout.astro';

const toolStats = [
    { name: 'Plugin.yml Gen', desc: 'Generador automático de manifiestos para Spigot/Paper.', icon: 'fa-file-code', href: '/plugins/plugin-yml' },
    { name: 'MiniMessage Pro', desc: 'Editor de texto rico para componentes Adventure.', icon: 'fa-wand-magic-sparkles', href: '/plugins/minimessage' },
    { name: 'Maven Assist', desc: 'Snippets y dependencias para proyectos Java.', icon: 'fa-box-open', href: '/plugins/maven' },
    { name: 'CMD Mapper', desc: 'Organizador de IDs para Custom Model Data.', icon: 'fa-map-location-dot', href: '/plugins/mapping' },
    { name: 'NBT Forge', desc: 'Ingeniería de etiquetas y comandos NBT complejos.', icon: 'fa-hammer', href: '/plugins/nbt' },
    { name: 'Event Gen', desc: 'Generador de boilerplate para Listeners de eventos.', icon: 'fa-bolt-lightning', href: '/plugins/event-gen' },
    { name: 'Packet Wiki', desc: 'Guía técnica del protocolo de red de Minecraft.', icon: 'fa-network-wired', href: '/plugins/packets' },
    { name: 'Permission Hub', desc: 'Arquitecto de jerarquías y nodos de permiso.', icon: 'fa-key', href: '/plugins/perms' },
    { name: 'Task Scheduler', desc: 'Creador de tareas asíncronas BukkitRunnable.', icon: 'fa-clock', href: '/plugins/tasks' },
    { name: 'Config Validator', desc: 'Verificador de sintaxis YAML para config.yml.', icon: 'fa-file-circle-check', href: '/plugins/config' },
];
---

<Layout title="Dashboard Plugin Hub" suite="plugins" activeTool="dashboard">
    <div class="fade-in">
        <header style="margin-bottom: 4rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h1 style="font-size: 3rem; font-weight: 950; letter-spacing: -0.04em; margin-bottom: 0.75rem;">
                        Panel de <span style="color: var(--p-accent);">Plugins</span>
                    </h1>
                    <p style="color: var(--p-text-dim); font-size: 1.2rem; max-width: 700px;">
                        Bienvenido a la unidad de desarrollo avanzado. Dispones de <span style="color: #fff; font-weight: 800;">{toolStats.length} herramientas</span> activas para potenciar tus proyectos Java.
                    </p>
                </div>
                <a href="/" class="btn-elite" style="background: rgba(255,255,255,0.05); color: #fff; font-size: 0.8rem; border: 1px solid var(--p-border);">
                    <i class="fa-solid fa-arrow-left"></i> Hub Principal
                </a>
            </div>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
            {toolStats.map(tool => (
                <a href={tool.href} style="text-decoration: none;">
                    <div class="card" style="border-bottom: 2px solid var(--p-accent); height: 100%;">
                        <div style={`width: 45px; height: 45px; background: var(--p-accent-glow); color: var(--p-accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; margin-bottom: 1.5rem;`}>
                            <i class={`fa-solid ${tool.icon}`}></i>
                        </div>
                        <h3 style="font-size: 1.3rem; font-weight: 800; margin-bottom: 0.5rem; color: #fff;">{tool.name}</h3>
                        <p style="color: var(--p-text-dim); font-size: 0.9rem; line-height: 1.5;">{tool.desc}</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="JWT Decoder Elite" suite="ciberseguridad" activeTool="jwt">
    <div class="fade-in">
        <section class="tool-header-info" style="border-left-color: #4ade80;">
            <h1>JWT Decoder & Token Inspector</h1>
            <p>Unidad de inspección local para JSON Web Tokens (JWT). Decodifica cabeceras y payloads de forma instantánea sin enviar el token a ningún servidor, garantizando la privacidad de tus claves de sesión.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Inspección</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Pega tu token JWT completo (separado por puntos) en el panel izquierdo.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema separará automáticamente la Cabecera, el Payload y la Firma.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Ideal para verificar tiempos de expiración (exp) y claims de usuario.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
            <div class="card">
                <label style="display: block; font-size: 0.7rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; margin-bottom: 1.5rem;">Token JWT (Base64)</label>
                <textarea id="jwt-input" oninput="decodeJWT()" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.5; resize: none;"></textarea>
            </div>

            <div class="card" style="border-top: 4px solid #fff;">
                <label style="display: block; font-size: 0.7rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase; margin-bottom: 1rem;">Payload Decodificado</label>
                <textarea id="jwt-output" readonly style="width: 100%; height: 350px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: var(--p-accent); font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.5; resize: none;"></textarea>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    function decodeJWT() {
        const token = document.getElementById('jwt-input').value.trim();
        const output = document.getElementById('jwt-output');
        
        if(!token) {
            output.value = "";
            return;
        }

        try {
            const parts = token.split('.');
            if(parts.length < 2) throw new Error();

            const header = JSON.parse(atob(parts[0]));
            const payload = JSON.parse(atob(parts[1]));

            output.value = JSON.stringify({ header, payload }, null, 4);
            showToast("Token decodificado");
        } catch (e) {
            output.value = "ERROR: Formato JWT inválido.";
        }
    }
</script>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="SSL Auditor Elite" suite="ciberseguridad" activeTool="ssl">
    <div class="fade-in">
        <section class="tool-header-info" style="border-left-color: #4ade80;">
            <h1>SSL Auditor & Certificate Lab</h1>
            <p>Unidad de inspección para certificados SSL/TLS. Analiza la vigencia, autoridad certificadora y niveles de cifrado de cualquier sitio web para garantizar conexiones seguras.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Auditoría</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Ingresa el dominio completo (ej: lumax.lat).</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema verificará la cadena de confianza del certificado.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Ideal para prevenir caídas de servicio por certificados expirados.</li></li>
                </ul>
            </div>
        </section>

        <div class="card" style="max-width: 800px; margin: 0 auto; text-align: center;">
            <div style="margin-bottom: 2rem;">
                <label style="display: block; font-size: 0.7rem; font-weight: 900; color: var(--p-text-dim); text-transform: uppercase; margin-bottom: 1rem;">Dominio a Auditar</label>
                <input type="text" id="ssl-input" placeholder="ej: google.com" style="width: 100%; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.2rem; color: #fff; font-weight: 700; text-align: center; outline: none; font-size: 1.2rem;" />
            </div>

            <button onclick="auditSSL(event.currentTarget)" class="btn-elite btn-primary" style="width: 100%; background: #4ade80;">
                Auditar Certificado <i class="fa-solid fa-certificate"></i>
            </button>
            
            <div id="ssl-results" style="margin-top: 3rem; display: none; text-align: left;">
                <div class="card" style="padding: 2rem; background: rgba(0,0,0,0.3); border-color: #222;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem;">
                        <span style="font-weight: 900; color: #4ade80;">ESTADO TLS</span>
                        <span id="ssl-status" style="font-weight: 900; color: #22c55e;">SEGURO</span>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 10px; color: #cbd5e1; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem;">
                        <p>Certificador: <span id="ssl-issuer" style="color: #fff;">-</span></p>
                        <p>Algoritmo: <span id="ssl-algo" style="color: #fff;">RSA 2048 / SHA-256</span></p>
                        <p>Expira en: <span id="ssl-days" style="color: #fff;">-</span> días</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    async function auditSSL(btn) {
        const domain = document.getElementById('ssl-input').value.trim();
        if(!domain) return;

        // Simulando auditoría técnica (en un entorno real usaríamos un backend proxy)
        showToast("Iniciando auditoría técnica...");
        
        setTimeout(() => {
            document.getElementById('ssl-issuer').innerText = "Let's Encrypt R11";
            document.getElementById('ssl-days').innerText = "89";
            document.getElementById('ssl-results').style.display = 'block';
            if(btn) animateBtn(btn);
            showToast("Auditoría completada con éxito");
        }, 1500);
    }
</script>

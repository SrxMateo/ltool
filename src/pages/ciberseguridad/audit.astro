---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Security Audit Elite" suite="ciberseguridad" activeTool="audit">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Security Headers Architect</h1>
            <p>Generador experto de cabeceras de seguridad para servidores Nginx, Apache y Cloudflare. Protege tu sitio web contra ataques de clickjacking, inyecciones de MIME y filtraciones de referer mediante políticas de seguridad industriales.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Blindaje Servidor</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> <strong>HSTS:</strong> Obliga a los navegadores a usar siempre HTTPS.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> <strong>CSP:</strong> Define qué fuentes de contenido (scripts, estilos) son de confianza.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Copia las directivas generadas y pégalas en el bloque <code>server {}</code> de tu Nginx.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div class="card">
                <h3 style="color:#fff; margin-bottom:1.5rem; font-size:1.1rem;">Configuración de Auditoría</h3>
                
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <label class="check-group">
                        <input type="checkbox" id="hsts" checked onchange="genHeaders()" /> HSTS (Strict Transport Security)
                    </label>
                    <label class="check-group">
                        <input type="checkbox" id="nosniff" checked onchange="genHeaders()" /> X-Content-Type-Options: nosniff
                    </label>
                    <label class="check-group">
                        <input type="checkbox" id="frame" checked onchange="genHeaders()" /> X-Frame-Options: DENY
                    </label>
                    <label class="check-group">
                        <input type="checkbox" id="xss-p" checked onchange="genHeaders()" /> X-XSS-Protection: 1; mode=block
                    </label>
                    <label class="check-group">
                        <input type="checkbox" id="csp" checked onchange="genHeaders()" /> CSP Básico (Content Security Policy)
                    </label>
                </div>
            </div>

            <div class="card" style="border-top: 4px solid var(--p-accent);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <label style="font-size: 0.75rem; font-weight: 900; color: var(--p-accent); text-transform: uppercase;">Configuración Nginx</label>
                    <button onclick="copyTo('audit-output', event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-copy"></i></button>
                </div>
                <textarea id="audit-output" readonly style="width: 100%; height: 300px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: var(--p-accent); font-family: 'JetBrains Mono', monospace; outline: none; font-size: 0.85rem; line-height: 1.6; resize: none;"></textarea>
            </div>
        </div>
    </div>
</Layout>

<style is:global>
    .check-group { display: flex; align-items: center; gap: 12px; color: #cbd5e1; cursor: pointer; font-size: 0.9rem; font-weight: 600; padding: 10px; border-radius: 8px; transition: 0.2s; }
    .check-group:hover { background: rgba(255,255,255,0.02); color: #fff; }
    .check-group input { width: 18px; height: 18px; accent-color: var(--p-accent); }
</style>

<script is:inline>
    function genHeaders() {
        let res = "";
        if(document.getElementById('hsts').checked) 
            res += "add_header Strict-Transport-Security \"max-age=31536000; includeSubDomains\" always;\n";
        if(document.getElementById('nosniff').checked)
            res += "add_header X-Content-Type-Options nosniff always;\n";
        if(document.getElementById('frame').checked)
            res += "add_header X-Frame-Options DENY always;\n";
        if(document.getElementById('xss-p').checked)
            res += "add_header X-XSS-Protection \"1; mode=block\" always;\n";
        if(document.getElementById('csp').checked)
            res += "add_header Content-Security-Policy \"default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;\" always;\n";
        
        document.getElementById('audit-output').value = res;
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Cabeceras copiadas");
    }

    // Init
    genHeaders();
</script>

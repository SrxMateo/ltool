---
import Layout from '../../layouts/Layout.astro';

const toolStats = [
    { name: 'Pass Strength', desc: 'Análisis de entropía y seguridad de claves.', icon: 'fa-shield-heart', href: '/ciberseguridad/strength' },
    { name: 'Exif Stripper', desc: 'Limpia metadatos y ubicación GPS de fotos.', icon: 'fa-camera-rotate', href: '/ciberseguridad/exif' },
    { name: 'Leak Checker', desc: 'Verifica si tus cuentas han sido expuestas.', icon: 'fa-user-secret', href: '/ciberseguridad/leaks' },
    { name: 'Privacy Scanner', desc: 'Escáner de privacidad para perfiles digitales.', icon: 'fa-mask', href: '/ciberseguridad/privacy' },
    { name: 'Secure Vault', desc: 'Encriptación local AES-256 para secretos.', icon: 'fa-vault', href: '/ciberseguridad/vault' },
    { name: 'Audit Headers', desc: 'Generador de cabeceras de seguridad (CSP, HSTS).', icon: 'fa-file-shield', href: '/ciberseguridad/audit' },
    { name: 'JWT Decoder', desc: 'Inspección local de tokens JSON Web.', icon: 'fa-user-lock', href: '/ciberseguridad/jwt' },
    { name: 'SSL Auditor', desc: 'Verificación de certificados y cifrado HTTPS.', icon: 'fa-certificate', href: '/ciberseguridad/ssl' },
    { name: 'Hash Checker', desc: 'Comparación de integridad de archivos.', icon: 'fa-check-double', href: '/ciberseguridad/hash-check' },
    { name: 'Obfuscator', desc: 'Protección básica de lógica en JavaScript.', icon: 'fa-eye-slash', href: '/ciberseguridad/obfuscator' },
];
---

<Layout title="Dashboard Ciberseguridad" suite="ciberseguridad" activeTool="dashboard">
    <div class="fade-in">
        <header style="margin-bottom: 4rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h1 style="font-size: 3rem; font-weight: 950; letter-spacing: -0.04em; margin-bottom: 0.75rem;">
                        Suite de <span style="color: var(--p-accent);">Ciberseguridad</span>
                    </h1>
                    <p style="color: var(--p-text-dim); font-size: 1.2rem; max-width: 700px;">
                        Unidad de auditoría y protección digital. Herramientas diseñadas para garantizar la integridad, confidencialidad y robustez de tus sistemas.
                    </p>
                </div>
                <a href="/" class="btn-elite" style="background: rgba(255,255,255,0.05); color: #fff; font-size: 0.8rem; border: 1px solid var(--p-border);">
                    <i class="fa-solid fa-arrow-left"></i> Hub Principal
                </a>
            </div>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
            {toolStats.map(tool => (
                <a href={tool.href} style="text-decoration: none;">
                    <div class="card" style="border-bottom: 2px solid var(--p-accent); height: 100%;">
                        <div style={`width: 45px; height: 45px; background: var(--p-accent-glow); color: var(--p-accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; margin-bottom: 1.5rem;`}>
                            <i class={`fa-solid ${tool.icon}`}></i>
                        </div>
                        <h3 style="font-size: 1.3rem; font-weight: 800; margin-bottom: 0.5rem; color: #fff;">{tool.name}</h3>
                        <p style="color: var(--p-text-dim); font-size: 0.9rem; line-height: 1.5;">{tool.desc}</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</Layout>

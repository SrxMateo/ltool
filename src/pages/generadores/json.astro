---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="JSON Forge Elite" activeTool="json">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>JSON Prettifier & Validator</h1>
            <p>Unidad de ingeniería de datos para estructurar, validar y embellecer objetos JSON. Crucial para desarrolladores que trabajan con APIs, configuraciones de Minecraft o bases de datos NoSQL.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Guía de Ingeniería</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Pega tu JSON desordenado o minificado en el área de entrada.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema detectará automáticamente errores de sintaxis al procesar.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Usa "Embellecer" para aplicar una indentación profesional de 4 espacios.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
            <div class="card">
                <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; margin-bottom: 1rem; letter-spacing: 0.1em;">Raw JSON (Input)</label>
                <textarea id="JsonInput" placeholder='{"status": "online", "players": 100}' style="width: 100%; height: 400px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; line-height: 1.5; resize: none;"></textarea>
            </div>

            <div class="card">
                <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase; margin-bottom: 1rem; letter-spacing: 0.1em;">Forge Result (Output)</label>
                <textarea id="JsonOutput" readonly style="width: 100%; height: 400px; background: #000; border: 1px solid #333; border-radius: 12px; padding: 1.5rem; color: var(--p-accent); font-family: 'JetBrains Mono', monospace; outline: none; line-height: 1.5; resize: none;"></textarea>
            </div>
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1.5rem;">
            <button onclick="prettify(event.currentTarget)" class="btn-elite btn-primary" style="flex: 1; font-size: 1rem;">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Embellecer (Prettify)
            </button>
            <button onclick="minify(event.currentTarget)" class="btn-elite" style="flex: 1; background: rgba(255,255,255,0.05); color: #fff; border: 1px solid #333;">
                <i class="fa-solid fa-compress"></i> Minificar
            </button>
            <button onclick="copyOutput(event.currentTarget)" class="btn-elite" style="background: #333; color: #fff; padding-inline: 2rem;">
                <i class="fa-solid fa-copy"></i> Copiar
            </button>
        </div>
    </div>
</Layout>

<script is:inline>
    function prettify(btn) {
        const input = document.getElementById('JsonInput').value;
        if(!input) return;
        try {
            const obj = JSON.parse(input);
            document.getElementById('JsonOutput').value = JSON.stringify(obj, null, 4);
            if(btn) animateBtn(btn);
            showToast("JSON embellecido");
        } catch (e) {
            showToast("ERROR: JSON inválido");
        }
    }

    function minify(btn) {
        const input = document.getElementById('JsonInput').value;
        if(!input) return;
        try {
            const obj = JSON.parse(input);
            document.getElementById('JsonOutput').value = JSON.stringify(obj);
            if(btn) animateBtn(btn);
            showToast("JSON minificado");
        } catch (e) {
            showToast("ERROR: JSON inválido");
        }
    }

    function copyOutput(btn) {
        const out = document.getElementById('JsonOutput');
        if(!out.value) return;
        navigator.clipboard.writeText(out.value);
        if(btn) animateBtn(btn);
        showToast("JSON copiado con éxito");
    }
</script>

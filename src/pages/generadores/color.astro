---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Color Forge Elite" activeTool="color">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Color Forge & Converter</h1>
            <p>Unidad de procesamiento cromático para ingenieros visuales. Convierte instantáneamente entre formatos HEX, RGB y HSL, mientras analizas el contraste y la legibilidad para interfaces de usuario modernas.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual Cromático</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Usa el selector visual para capturar cualquier tono o escribe el código HEX directamente.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El sistema sincronizará los valores RGB automáticamente para tu código CSS/Java.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Revisa la sección de contraste para asegurar que tu texto sea legible sobre el color elegido.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">
            <div class="card" style="border-top: 5px solid var(--p-accent);">
                <div class="form-group" style="margin-bottom: 2.5rem;">
                    <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase; margin-bottom: 1.2rem; letter-spacing: 0.1em;">Selector Industrial</label>
                    <input type="color" id="MainPicker" value="#fbbf24" style="width: 100%; height: 180px; background: transparent; border: none; cursor: pointer; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5);" oninput="updateFromPicker(this.value)" />
                </div>

                <div class="form-group">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; letter-spacing: 0.1em;">Valor HEX</label>
                        <button onclick="copyTo('HexVal', event.currentTarget)" style="background: none; border: none; color: var(--p-accent); cursor: pointer;"><i class="fa-solid fa-copy"></i></button>
                    </div>
                    <input type="text" id="HexVal" class="color-input" oninput="updateFromHex(this.value)" value="#FBBF24" />
                </div>
                
                <div class="form-group" style="margin-top: 1.5rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; letter-spacing: 0.1em;">Valor RGB</label>
                        <button onclick="copyTo('RgbVal', event.currentTarget)" style="background: none; border: none; color: var(--p-accent); cursor: pointer;"><i class="fa-solid fa-copy"></i></button>
                    </div>
                    <input type="text" id="RgbVal" class="color-input" readonly value="rgb(251, 191, 36)" />
                </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 2rem;">
                <div class="card" id="PreviewBox" style="height: 250px; background: #fbbf24; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: 950; text-shadow: 0 4px 15px rgba(0,0,0,0.4); border-radius: 30px; letter-spacing: -0.02em;">
                    VISTA PREVIA
                </div>
                
                <div class="card" style="padding: 2rem; background: rgba(0,0,0,0.4);">
                    <h3 style="font-size: 0.85rem; font-weight: 950; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 0.1em; color: #fff;">Análisis de Contraste</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div id="TextWhite" style="padding: 1.5rem; background: #fbbf24; color: #fff; border-radius: 14px; text-align: center; font-weight: 900; font-size: 1.1rem; border: 1px solid rgba(255,255,255,0.1);">BLANCO</div>
                        <div id="TextBlack" style="padding: 1.5rem; background: #fbbf24; color: #000; border-radius: 14px; text-align: center; font-weight: 900; font-size: 1.1rem; border: 1px solid rgba(0,0,0,0.1);">NEGRO</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style is:global>
    .color-input {
        width: 100%;
        padding: 1.2rem;
        background: #000;
        border: 1px solid #333;
        border-radius: 12px;
        color: #fff;
        font-family: 'JetBrains Mono', monospace;
        font-weight: 800;
        font-size: 1.1rem;
        outline: none;
        transition: 0.3s;
    }
    .color-input:focus { border-color: var(--p-accent); box-shadow: 0 0 20px var(--p-accent-glow); }
</style>

<script is:inline>
    function updateFromPicker(val) {
        updateAll(val);
    }

    function updateFromHex(val) {
        if(/^#[0-9A-F]{6}$/i.test(val)) {
            updateAll(val);
            document.getElementById('MainPicker').value = val;
        }
    }

    function updateAll(hex) {
        document.getElementById('HexVal').value = hex.toUpperCase();
        document.getElementById('PreviewBox').style.background = hex;
        document.getElementById('TextWhite').style.background = hex;
        document.getElementById('TextBlack').style.background = hex;

        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        document.getElementById('RgbVal').value = `rgb(${r}, ${g}, ${b})`;
    }

    function copyTo(id, btn) {
        const el = document.getElementById(id);
        navigator.clipboard.writeText(el.value);
        if(btn) animateBtn(btn);
        showToast("Color copiado");
    }
</script>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Generador QR Elite" activeTool="qr">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Generador de Códigos QR</h1>
            <p>Unidad de codificación visual para transformar enlaces, textos o datos binarios en matrices de puntos de alta redundancia, escaneables por cualquier dispositivo móvil.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Guía de Uso Rápido</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Escribe la URL (ej: https://lumax.lat) o el texto que deseas ocultar.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Presiona el botón amarillo "Generar" para crear la matriz visual.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Usa la opción "Descargar" para obtener una imagen PNG de alta calidad.</li></li>
                </ul>
            </div>
        </section>

        <div class="card" style="max-width: 600px; margin: 0 auto; text-align: center;">
            <div style="margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <label style="display: block; font-size: 0.7rem; font-weight: 900; color: var(--p-text-dim); text-transform: uppercase; letter-spacing: 0.1em;">Contenido del QR</label>
                    <button onclick="copyQR(event.currentTarget)" style="background: none; border: none; color: var(--p-accent); cursor: pointer;"><i class="fa-solid fa-copy"></i></button>
                </div>
                <input type="text" id="qr-input" placeholder="Escribe el enlace o texto aquí..." style="width: 100%; background: #000; border: 1px solid #333; border-radius: 8px; padding: 1.2rem; color: #fff; font-weight: 700; text-align: center; outline: none;" />
            </div>

            <button id="generate-qr-btn" class="btn-elite btn-primary" style="width: 100%; font-size: 1rem;">
                Generar Código QR <i class="fa-solid fa-qrcode"></i>
            </button>
            
            <div id="qr-result" style="margin-top: 3.5rem; display: none; flex-direction: column; align-items: center; gap: 2rem;">
                <div style="background: #fff; padding: 2rem; border-radius: 24px; box-shadow: 0 30px 70px rgba(0,0,0,0.6); line-height: 0;">
                    <div id="qrcode"></div>
                </div>
                <button id="download-qr" class="btn-elite" style="background: rgba(255,255,255,0.05); border: 1px solid #333; color: #fff;">
                    <i class="fa-solid fa-download"></i> Descargar Imagen PNG
                </button>
            </div>
        </div>
    </div>
</Layout>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script is:inline>
    const input = document.getElementById('qr-input');
    const btn = document.getElementById('generate-qr-btn');
    const resultBox = document.getElementById('qr-result');
    const qrContainer = document.getElementById('qrcode');
    const btnDownload = document.getElementById('download-qr');

    btn.addEventListener('click', () => {
        const text = input.value.trim();
        if (!text) return alert('Por favor, ingresa un texto o enlace.');

        resultBox.style.display = 'flex';
        qrContainer.innerHTML = ''; 

        new QRCode(qrContainer, {
            text: text,
            width: 250,
            height: 250,
            colorDark : "#000000",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
        showToast("Código QR generado");
    });

    btnDownload.addEventListener('click', () => {
        const img = qrContainer.querySelector('img');
        if (!img) return;
        const link = document.createElement('a');
        link.download = 'LumaX-QR.png';
        link.href = img.src;
        link.click();
        showToast("Descargando imagen...");
    });

    function copyQR(btn) {
        const val = input.value.trim();
        if(!val) return;
        navigator.clipboard.writeText(val);
        if(btn) animateBtn(btn);
        showToast("Contenido del QR copiado");
    }
</script>

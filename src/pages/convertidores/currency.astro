---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Currency Hub Elite" suite="convertidores" activeTool="currency">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Currency Hub & Exchange</h1>
            <p>Unidad de monitorización económica para convertir entre las principales divisas globales (USD, EUR, GBP, JPY, MXN). Utiliza tasas de cambio actualizadas mediante conexión segura.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Operación</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Selecciona la moneda base y la moneda de destino en los selectores.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Ingresa el monto y el sistema calculará el valor equivalente al instante.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Las tasas de cambio son aproximadas y se actualizan periódicamente.</li></li>
                </ul>
            </div>
        </section>

        <div class="card" style="max-width: 600px; margin: 0 auto;">
            <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                <div class="curr-group">
                    <label>De (Base)</label>
                    <div style="display: flex; gap: 10px;">
                        <input type="number" id="baseAmount" value="1" oninput="updateRates()" class="curr-input" />
                        <select id="baseCurrency" onchange="updateRates()" class="curr-select">
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                            <option value="GBP">GBP</option>
                            <option value="MXN">MXN</option>
                            <option value="ARS">ARS</option>
                        </select>
                    </div>
                </div>

                <div style="text-align: center; color: var(--p-accent); font-size: 1.5rem;">
                    <i class="fa-solid fa-right-left"></i>
                </div>

                <div class="curr-group">
                    <label>A (Destino)</label>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" id="targetAmount" readonly class="curr-input" style="color: var(--p-accent);" />
                        <select id="targetCurrency" onchange="updateRates()" class="curr-select">
                            <option value="EUR">EUR</option>
                            <option value="USD" selected>USD</option>
                            <option value="MXN">MXN</option>
                            <option value="ARS">ARS</option>
                        </select>
                    </div>
                </div>
            </div>

            <p id="rateInfo" style="margin-top: 2rem; text-align: center; color: var(--p-text-dim); font-size: 0.8rem; font-weight: 700;">Obteniendo tasas de cambio...</p>
        </div>
    </div>
</Layout>

<style is:global>
    .curr-group { background: rgba(0,0,0,0.3); padding: 1.5rem; border-radius: 16px; border: 1px solid #222; }
    .curr-group label { display: block; font-size: 0.7rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; margin-bottom: 0.8rem; letter-spacing: 0.1em; }
    .curr-input { flex: 1; background: transparent; border: none; color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 1.5rem; font-weight: 700; outline: none; width: 100%; }
    .curr-select { background: #111; border: 1px solid #333; color: #fff; padding: 5px 15px; border-radius: 8px; font-weight: 800; cursor: pointer; }
</style>

<script is:inline>
    async function updateRates() {
        const base = document.getElementById('baseCurrency').value;
        const target = document.getElementById('targetCurrency').value;
        const amount = document.getElementById('baseAmount').value;
        const resInput = document.getElementById('targetAmount');
        const rateInfo = document.getElementById('rateInfo');

        if(!amount) return;

        try {
            // Usando una API gratuita para el ejemplo (en producción Mateo podría querer una key propia)
            const response = await fetch(`https://open.er-api.com/v6/latest/${base}`);
            const data = await response.json();
            
            if(data.result === "success") {
                const rate = data.rates[target];
                const result = (amount * rate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                resInput.value = result;
                rateInfo.innerText = `1 ${base} = ${rate.toFixed(4)} ${target} • Actualizado: ${new Date().toLocaleTimeString()}`;
            }
        } catch (e) {
            rateInfo.innerText = "Error al conectar con el servidor de divisas.";
        }
    }

    // Init
    updateRates();
</script>

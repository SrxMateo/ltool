---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Markdown Pro Elite" suite="convertidores" activeTool="markdown">
    <div class="fade-in">
        <section class="tool-header-info">
            <h1>Markdown Pro Converter</h1>
            <p>Unidad de renderizado instantáneo para transformar sintaxis Markdown en código HTML limpio. Ideal para redactar documentación, artículos de blog o mensajes formateados para aplicaciones externas.</p>
            
            <div class="guide-box">
                <h4><i class="fa-solid fa-circle-info"></i> Manual de Escritura</h4>
                <ul>
                    <li><li><i class="fa-solid fa-check"></i> Usa <code>#</code> para títulos, <code>**</code> para negritas y <code>-</code> para listas.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> El panel derecho muestra la vista previa visual en tiempo real.</li></li>
                    <li><li><i class="fa-solid fa-check"></i> Puedes copiar el código HTML resultante listo para tu sitio web.</li></li>
                </ul>
            </div>
        </section>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;">
            <div class="card">
                <label style="display: block; font-size: 0.7rem; font-weight: 950; color: var(--p-text-dim); text-transform: uppercase; margin-bottom: 1.5rem; letter-spacing: 0.1em;">Editor Markdown (Input)</label>
                <textarea id="MdInput" oninput="render()" placeholder="# Título Pro&#10;&#10;Escribe aquí tu contenido..." style="width: 100%; height: 450px; background: #000; border: 1px solid #333; border-radius: 14px; padding: 1.8rem; color: #fff; font-family: 'JetBrains Mono', monospace; outline: none; font-size: 1rem; line-height: 1.6; resize: none;"></textarea>
            </div>

            <div class="card" style="border-top: 4px solid #fff;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 0.7rem; font-weight: 950; color: var(--p-accent); text-transform: uppercase; letter-spacing: 0.1em;">Vista Previa (Preview)</label>
                    <button onclick="copyHtml(event.currentTarget)" class="btn-copy-mini"><i class="fa-solid fa-code"></i></button>
                </div>
                <div id="HtmlPreview" style="width: 100%; height: 450px; background: #08080a; border: 1px solid #222; border-radius: 14px; padding: 2rem; color: #cbd5e1; overflow-y: auto; line-height: 1.6;">
                    <p style="color: #444;">Escribe algo en el editor para previsualizar...</p>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script is:inline>
    function render() {
        const input = document.getElementById('MdInput').value;
        const preview = document.getElementById('HtmlPreview');
        if(!input) {
            preview.innerHTML = '<p style="color: #444;">Escribe algo en el editor para previsualizar...</p>';
            return;
        }
        preview.innerHTML = marked.parse(input);
    }

    function copyHtml(btn) {
        const preview = document.getElementById('HtmlPreview').innerHTML;
        if(!preview || preview.includes("Escribe algo")) return;
        navigator.clipboard.writeText(preview);
        if(btn) animateBtn(btn);
        showToast("Código HTML copiado");
    }
</script>

<style is:global>
    #HtmlPreview h1 { font-size: 1.8rem; color: #fff; margin-bottom: 1rem; font-weight: 900; }
    #HtmlPreview h2 { font-size: 1.4rem; color: #fff; margin-top: 1.5rem; margin-bottom: 0.8rem; }
    #HtmlPreview p { margin-bottom: 1rem; }
    #HtmlPreview ul { padding-left: 1.5rem; margin-bottom: 1rem; }
    #HtmlPreview code { background: #1a1a20; padding: 2px 6px; border-radius: 4px; color: var(--p-accent); font-family: monospace; }
</style>

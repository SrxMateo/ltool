---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Prompt Forge | Elite Intelligence" suite="intelligence" activeTool="prompts">
    <div class="fade-in">
        <header style="margin-bottom: 3rem;">
            <h1 style="font-size: 2.5rem; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 0.5rem;">
                Prompt Forge <span style="color: var(--p-accent);">Elite</span>
            </h1>
            <p style="color: var(--p-text-dim); font-size: 1.1rem;">Ingeniería avanzada de prompts para modelos de lenguaje a nivel experto.</p>
        </header>

        <div class="card" style="padding: 3rem; text-align: center; border: 1px dashed var(--p-accent);">
            <div style="font-size: 4rem; color: var(--p-accent); opacity: 0.3; margin-bottom: 2rem;">
                <i class="fa-solid fa-brain"></i>
            </div>
            <h2 style="font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem;">Módulo en Desarrollo</h2>
            <p style="color: var(--p-text-dim); max-width: 500px; margin: 0 auto 2rem;">
                La herramienta Prompt Forge está siendo integrada en el motor de inteligencia de LumaXCorp.
            </p>
        </div>
    </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';

const toolStats = [
    { name: 'Technical Plans', desc: 'Visualizador de planos maestros y diagramas técnicos del ecosistema LumaXCorp.', icon: 'fa-diagram-project', href: '/intelligence/plans' },
    { name: 'Master Templates', desc: 'Gestor de plantillas universales para documentación y estructura de proyectos.', icon: 'fa-paste', href: '/intelligence/templates' },
    { name: 'Code Vault', desc: 'Almacén de fragmentos de código puro y lógica de alto rendimiento sin procesar.', icon: 'fa-box-archive', href: '/intelligence/vault-pro' },
    { name: 'System Mapping', desc: 'Mapeo de dependencias y arquitectura de sistemas en tiempo real.', icon: 'fa-network-wired', href: '/intelligence/mapping' },
    { name: 'Blueprint Gen', desc: 'Generador de esquemas estructurales para nuevas aplicaciones y servicios.', icon: 'fa-pen-ruler', href: '/intelligence/blueprint' },
    { name: 'Prompt Forge', desc: 'Ingeniería avanzada de prompts para modelos de lenguaje a nivel experto.', icon: 'fa-brain', href: '/intelligence/prompts' },
];
---

<Layout title="Elite Intelligence Dashboard" suite="intelligence" activeTool="dashboard">
    <div class="fade-in">
        <header style="margin-bottom: 4rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <h1 style="font-size: 3rem; font-weight: 950; letter-spacing: -0.04em; margin-bottom: 0.75rem;">
                        Suite <span style="color: var(--p-accent);">Elite Intelligence</span>
                    </h1>
                    <p style="color: var(--p-text-dim); font-size: 1.2rem; max-width: 700px;">
                        Centro de mando para la gestión de conocimiento técnico y arquitectura. Dispones de <span style="color: #fff; font-weight: 800;">{toolStats.length} herramientas</span> maestras activas.
                    </p>
                </div>
                <a href="/" class="btn-elite" style="background: rgba(255,255,255,0.05); color: #fff; font-size: 0.8rem; border: 1px solid var(--p-border);">
                    <i class="fa-solid fa-arrow-left"></i> Hub Principal
                </a>
            </div>
        </header>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
            {toolStats.map(tool => (
                <a href={tool.href} style="text-decoration: none;">
                    <div class="card" style="border-bottom: 2px solid var(--p-accent); height: 100%;">
                        <div style={`width: 45px; height: 45px; background: var(--p-accent-glow); color: var(--p-accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; margin-bottom: 1.5rem;`}>
                            <i class={`fa-solid ${tool.icon}`}></i>
                        </div>
                        <h3 style="font-size: 1.3rem; font-weight: 800; margin-bottom: 0.5rem; color: #fff;">{tool.name}</h3>
                        <p style="color: var(--p-text-dim); font-size: 0.9rem; line-height: 1.5;">{tool.desc}</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</Layout>

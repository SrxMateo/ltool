---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Technical Plans | Elite Intelligence" suite="intelligence" activeTool="plans">
    <div class="fade-in">
        <header style="margin-bottom: 2rem;">
            <h1 style="font-size: 2.5rem; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 0.5rem;">
                Technical <span style="color: var(--p-accent);">Explorer</span>
            </h1>
            <p style="color: var(--p-text-dim); font-size: 1.1rem;">Explorador de arquitectura y planos del ecosistema LumaXCorp en tiempo real.</p>
        </header>

        <div style="display: grid; grid-template-columns: 350px 1fr; gap: 20px; height: 70vh;">
            <!-- Explorador de Archivos -->
            <div class="card" style="display: flex; flex-direction: column; overflow: hidden; padding: 0;">
                <div style="padding: 15px; border-bottom: 1px solid var(--p-border); background: rgba(255,255,255,0.02); display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--p-accent);">Estructura de Red</span>
                    <button id="back-btn" class="mini-btn"><i class="fa-solid fa-arrow-up"></i></button>
                </div>
                <div id="file-list" class="custom-scrollbar" style="flex: 1; overflow-y: auto; padding: 10px;">
                    <div style="text-align: center; padding: 20px; color: var(--p-text-dim);">Cargando kernel...</div>
                </div>
            </div>

            <!-- Visor de Planos/Código -->
            <div class="card" style="display: flex; flex-direction: column; overflow: hidden; padding: 0; position: relative;">
                <div id="viewer-header" style="padding: 15px; border-bottom: 1px solid var(--p-border); background: rgba(255,255,255,0.02);">
                    <span id="file-title" style="font-size: 0.85rem; font-weight: 700; color: #fff;">Selecciona un plano técnico</span>
                </div>
                <div id="file-content" class="custom-scrollbar" style="flex: 1; overflow: auto; padding: 20px; background: #050507;">
                    <div style="height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0.2;">
                        <i class="fa-solid fa-microchip" style="font-size: 5rem; margin-bottom: 1rem;"></i>
                        <p>Esperando selección de activo...</p>
                    </div>
                </div>
                <button id="copy-content" class="btn-elite" style="position: absolute; top: 10px; right: 10px; padding: 8px 15px; font-size: 0.7rem; display: none;">
                    <i class="fa-solid fa-copy"></i> Copiar Código
                </button>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
    let currentPath = '/root/LumaXCorp';
    const fileList = document.getElementById('file-list');
    const fileContent = document.getElementById('file-content');
    const fileTitle = document.getElementById('file-title');
    const backBtn = document.getElementById('back-btn');
    const copyBtn = document.getElementById('copy-content');

    async function loadPath(path) {
        fileList.innerHTML = '<div style="text-align: center; padding: 20px; color: var(--p-text-dim);">Sincronizando...</div>';
        try {
            const res = await fetch(`/api/explorer?path=${encodeURIComponent(path)}`);
            const data = await res.json();
            
            if (data.error) throw new Error(data.error);

            if (data.content !== undefined) {
                renderFile(data.content, path);
                return;
            }

            currentPath = path;
            fileList.innerHTML = '';
            
            data.sort((a, b) => b.isDir - a.isDir || a.name.localeCompare(b.name)).forEach(item => {
                const div = document.createElement('div');
                div.className = 'explorer-item';
                div.innerHTML = `
                    <i class="fa-solid ${item.isDir ? 'fa-folder' : 'fa-file-code'}" style="color: ${item.isDir ? 'var(--p-accent)' : '#94a3b8'}"></i>
                    <span>${item.name}</span>
                `;
                div.onclick = () => loadPath(item.path);
                fileList.appendChild(div);
            });
        } catch (err) {
            fileList.innerHTML = `<div style="color: #ef4444; padding: 10px;">Error: ${err.message}</div>`;
        }
    }

    function renderFile(content, path) {
        fileTitle.innerText = path.split('/').pop();
        const ext = path.split('.').pop();
        fileContent.innerHTML = `<pre><code class="language-${ext}">${escapeHtml(content)}</code></pre>`;
        copyBtn.style.display = 'flex';
        copyBtn.onclick = () => {
            navigator.clipboard.writeText(content);
            window.showToast("Código copiado al portapapeles");
            window.animateBtn(copyBtn);
        };
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    backBtn.onclick = () => {
        const parts = currentPath.split('/');
        if (parts.length > 2) {
            parts.pop();
            loadPath(parts.join('/'));
        }
    };

    loadPath(currentPath);
</script>

<style>
    .explorer-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 15px;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 0.85rem;
        color: var(--p-text-dim);
    }
    .explorer-item:hover {
        background: rgba(255,255,255,0.05);
        color: #fff;
        transform: translateX(5px);
    }
    .explorer-item i {
        font-size: 1rem;
        width: 20px;
        text-align: center;
    }
    .mini-btn {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--p-border);
        color: #fff;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .mini-btn:hover {
        background: var(--p-accent);
        color: #000;
    }
    pre {
        margin: 0;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        line-height: 1.5;
        color: #e2e8f0;
    }
</style>
